---
/**
 * SourceList — renders the research-portfolio inline `sources` (T1–T4 tiered) field.
 *
 * The scaffold VALIDATES `sources: [{tier, url, label}]` in frontmatter but ships no renderer
 * (the one real render gap). This surfaces them as a tiered reference list. Source TIER
 * (quality) is orthogonal to a block's I/R/V freshness class — the two are separate axes.
 */
interface Source { tier: "T1" | "T2" | "T3" | "T4"; url: string; label: string; }
interface Props { sources?: Source[]; heading?: string; }
const { sources = [], heading = "Sources" } = Astro.props;
const TIER = {
  T1: "primary (original)", T2: "authoritative secondary",
  T3: "explainer", T4: "conjecture/informal",
};
---
{sources.length > 0 && (
  <section class="source-list" aria-label="sources">
    <h4>{heading}</h4>
    <ul>
      {sources.map((s) => (
        <li data-tier={s.tier}>
          <span class="tier" title={TIER[s.tier]}>{s.tier}</span>{" "}
          <a href={s.url} rel="noopener">{s.label}</a>
        </li>
      ))}
    </ul>
  </section>
)}
