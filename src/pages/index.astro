---
import Base from '@brandon_m_behring/book-scaffold-astro/layouts/Base.astro';
import { normalizeBase } from '@brandon_m_behring/book-scaffold-astro';

const baseUrl = normalizeBase(import.meta.env.BASE_URL);
---
<Base title="Transformer Systems Engineering" description="A code-first companion to the formal transformer-mathematics guide: scale one reference-model family from decide to serve, with every number traceable to a runnable fixture.">
  <article class="prose">
    <h1>Transformer Systems Engineering</h1>
    <p>
      A code-first, nuts-and-bolts companion to the formal
      <em>Transformer Mathematics</em> guide. We take a single reference-model family
      &mdash; a small dense language model and its document-AI variant &mdash; and scale
      it along the buildable spine: <strong>decide &rarr; build &rarr; train &rarr; scale
      &rarr; serve</strong>. Every performance claim is instrumented; every number traces
      to a runnable fixture, and every source to a strict-live dossier.
    </p>
    <p>
      Start with
      <a href={baseUrl + 'chapters/'}>the chapters</a>, or jump to
      <a href={baseUrl + 'references/'}>references</a>,
      <a href={baseUrl + 'search/'}>search</a>, or the
      <a href={baseUrl + 'print/'}>print edition</a>.
    </p>
  </article>
</Base>
